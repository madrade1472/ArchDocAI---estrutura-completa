# LLM Provider: "openai" | "anthropic" | "custom"
LLM_PROVIDER=openai

# Your API key (OpenAI or Anthropic)
LLM_API_KEY=sk-...

# Model to use
# OpenAI:    gpt-4o | gpt-4-turbo | gpt-3.5-turbo
# Anthropic: claude-opus-4-6 | claude-sonnet-4-6
LLM_MODEL=gpt-4o

# Custom LLM base URL (optional, for self-hosted models)
LLM_BASE_URL=

# Output language: "pt" | "en"
OUTPUT_LANGUAGE=pt

# Output directory for generated files
OUTPUT_DIR=./output

# CORS: comma-separated allowed origins
# Use * for local development only. Restrict in production.
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=*

# Maximum repository size allowed for cloning (MB)
# Protects against disk exhaustion. Default: 500 MB
MAX_REPO_SIZE_MB=500

# Rate limiting: requests per window per IP
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=3600

# Max concurrent analysis jobs (prevents thread storm under load)
MAX_CONCURRENT_JOBS=5

# Job timeout in seconds (watchdog marks job as error after this; default 15 min)
JOB_TIMEOUT_SECONDS=900
